# Copy to .env and fill in. .env is gitignored — never commit it.
# After editing, run `make validate` (or scripts/deploy.sh) to check it.

# ── Caddy / TLS ───────────────────────────────────────────────────────────────
# Email Let's Encrypt uses for expiry notices / account recovery.
ACME_EMAIL=you@example.com

# Space-separated list of EVERY status-page (sub)domain to serve + route to Kuma.
# Add one per project. Each must (1) have a DNS A record pointing at this server
# and (2) be entered in that Status Page's "Domain Names" field in the Kuma UI.
STATUS_DOMAINS=status.tokscript.com status.tokdownload.com

# Dedicated host for the admin dashboard — kept off the public status domains.
ADMIN_DOMAIN=kuma-admin.example.com

# Basic Auth username for the admin host (on top of Kuma's own login).
# The PASSWORD HASH is NOT stored here — it lives in caddy/admin.hash (gitignored),
# because a bcrypt hash's '$' chars get mangled by Docker Compose interpolation.
# Set it once (prompts; keeps the plaintext out of shell history):  make hash
ADMIN_BASICAUTH_USER=admin

# ── Watchdog (out-of-band dead-man's switch) ──────────────────────────────────
# Public URL the watchdog curls to confirm Kuma is alive. The admin host returns
# 401 (Basic Auth) which still proves the app is up — that's expected.
KUMA_HEALTH_URL=https://kuma-admin.example.com

# Slack incoming-webhook the WATCHDOG posts to if Kuma itself is unreachable.
# This is separate from Kuma's own Slack notifications (set in the UI) — Kuma
# cannot alert that Kuma is down, so this is the out-of-band path. Keep secret.
SLACK_WEBHOOK_URL=

# Optional off-host dead-man's switch (e.g. a healthchecks.io ping URL). The
# watchdog pings it on every healthy run; if THIS host dies the pings stop and
# the external service alerts you. Leave blank to disable.
HEARTBEAT_PING_URL=
